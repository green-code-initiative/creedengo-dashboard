{
  "name": "creedengo-dashboard",
  "displayName": "Creedengo",
  "description": "Sustainability Ecoscore based on code analyses",
  "version": "0.0.1",
  "license": "GPL-2.0-or-later",
  "author": "Green Code Initiative",
  "homepage": "https://github.com/green-code-initiative/creedengo-dashboard#readme",
  "bugs": "https://github.com/green-code-initiative/creedengo-dashboard/issues",
  "repository": "https://github.com/green-code-initiative/creedengo-dashboard",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.102.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10",
      "onFail": "error"
    }
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./src/vscode/extension.js",
  "extensionDependencies": [
    "sonarsource.sonarlint-vscode"
  ],
  "contributes": {
    "views": {
      "SonarLint": [
        {
          "id": "Creedengo.Score",
          "name": "Sustainability Score",
          "type": "webview"
        }
      ]
    },
    "configuration": {
        "title": "Creedengo Dashboard Configuration",
        "properties": {
          "creedengo.sonarUrl": {
            "type": "string",
            "default": "http://localhost:3000/api",
            "description": "The Sonar Server URL."
          },
          "creedengo.sonarToken": {
            "type": "string",
            "default": "",
            "description": "The Sonar Authentication Token."
          },
          "creedengo.sonarOrganisationKey": {
            "type": "string",
            "default": "",
            "description": "The Sonar Organisation Key. Leave empty to use the one from sonar-project.properties."
          },
          "creedengo.sonarProjectKey": {
            "type": "string",
            "default": "",
            "description": "The Sonar Project Key. Leave empty to use the one from sonar-project.properties."
          },
          "creedengo.enableNotifications": {
            "type": "boolean",
            "default": true,
            "description": "Enable or disable notifications from Creedengo."
          }
        }
      },
		"commands": [
			{
				"command": "Creedengo.updateScore",
				"category": "Creedengo Score",
				"title": "Update Score",
        "icon": "$(sync~spin)"
			},
			{
				"command": "Creedengo.clearScore",
				"category": "Creedengo Score",
				"title": "Clear Score",
        "icon": "$(trash)"
			}
		]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:vscode": "vscode-test",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "coverage": "vitest run --coverage",
    "serve:sonar": "node src/api/sonar/mock/server.js",
    "sonar": "pnpm coverage && pnpm exec sonar-scanner -Dsonar.login=$SONAR -Dsonar.host.url=http://localhost:9000",
    "lint": "eslint src --fix",
    "format": "prettier --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "vue": "^3.5.17",
    "vue3-toastify": "^0.2.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.1",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@creedengo/eslint-plugin": "^2.1.0",
    "@eslint/compat": "^1.1.1",
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.53.1",
    "@storybook/addon-a11y": "9.0.15",
    "@storybook/addon-coverage": "^1.0.4",
    "@storybook/addon-docs": "^9.0.15",
    "@storybook/addon-links": "9.0.15",
    "@storybook/builder-vite": "^9.0.15",
    "@storybook/vue3": "9.0.15",
    "@storybook/vue3-vite": "9.0.15",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vue/test-utils": "^2.4.6",
    "axe-playwright": "^2.0.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-storybook": "^9.0.15",
    "eslint-plugin-vue": "^9.27.0",
    "globals": "^15.9.0",
    "jest": "^30.0.3",
    "jsdom": "^24.1.0",
    "msw": "^2.10.2",
    "msw-storybook-addon": "^2.0.5",
    "prettier": "3.5.3",
    "sonarqube-scanner": "^4.3.0",
    "storybook": "9.0.15",
    "transform": "link:@storybook/test-runner/playwright/transform",
    "vite": "^6.3.5",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vitest": "^3.2.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad"
}
